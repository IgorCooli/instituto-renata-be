# Copiar para .env (não versionar segredos reais).

# Perfil lógico do processo: local | staging | production (mapeado a spring.profiles.active se SPRING_PROFILES_ACTIVE não estiver definido).
ENV=local

# JDBC (perfil local — Postgres do compose em ../docker: admin/admin, base postgres, host localhost:5432).
# Se usares só o docker-compose.yml deste repo (porta 5433), usa: jdbc:postgresql://localhost:5433/postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin

# Em staging/produção, definir as três variáveis acima com os valores do ambiente.

# Porta HTTP (opcional; predefinido 8080 em application.yml).
# HTTP_PORT=8080

# Para testes Gradle, a tarefa `test` define SPRING_PROFILES_ACTIVE=test — não é necessário no .env.
